GALLERY_SOURCE_DIR=/absolute/path/to/gallery/artists-root
ALLOWED_DEV_ORIGIN=http://192.168.x.x:4317
GALLERY_TRASH_DIR=/absolute/path/to/trash-dir
GALLERY_CACHE_TTL_MS=300000
GALLERY_MEDIA_CACHE_DIR=/absolute/path/to/media-cache
ICON_SOURCE_PATH=/absolute/path/to/square-icon.png

# Optional: enable Clerk auth for public access
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# Invite-only sign-up gate (requires Clerk to be enabled)
# Generate INVITE_COOKIE_SECRET with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set ADMIN_USER_ID to your Clerk user ID (find it in Clerk Dashboard → Users).
# Only the admin can generate invite codes at /admin/invite.
INVITE_COOKIE_SECRET=replace_with_random_hex
ADMIN_USER_ID=user_replace_with_your_clerk_user_id
